<% layout("/layouts/boilerplate") %>

<body>
  <div class="container pt-2 pb-3">

    <!-- FILTER SECTION -->
    <div class="d-flex align-items-center justify-content-between mb-2">

      <!-- FILTERS -->
      <div 
        id="filters"
        class="d-flex flex-nowrap overflow-auto"
        style="gap:12px; white-space:nowrap;"
      >

        <% const filters = [
          {icon:"fas fa-fire", name:"Trending"},
          {icon:"fa-solid fa-bed", name:"Rooms"},
          {icon:"fa-solid fa-mountain-city", name:"Cities"},
          {icon:"fa-solid fa-mountain", name:"Mountains"},
          {icon:"fa-solid fa-chess-rook", name:"Castles"},
          {icon:"fa-solid fa-water-ladder", name:"Pools"},
          {icon:"fa-solid fa-campground", name:"Camping"},
          {icon:"fa-solid fa-umbrella-beach", name:"Beach"},
          {icon:"fa-solid fa-tree", name:"Nature"},
          {icon:"fa-solid fa-snowflake", name:"Snow"},
          {icon:"fa-solid fa-house", name:"Villas"},
          {icon:"fa-solid fa-ship", name:"Boats"},
          {icon:"fa-solid fa-tree-city", name:"Forest"}
        ]; %>

        <% filters.forEach(f => { %>
          <div style="min-width:70px; flex:0 0 auto; text-align:center; cursor:pointer;">
            <i class="<%= f.icon %>"></i>
            <p style="font-size:0.75rem; margin:0;"><%= f.name %></p>
          </div>
        <% }) %>

      </div>

      <!-- GST TOGGLE -->
      <div 
        class="ms-2 d-flex align-items-center"
        style="background:#fff; border:1px solid #ddd; border-radius:25px; padding:6px 12px; gap:6px;"
      >
        <span style="font-size:0.8rem; white-space:nowrap;">
          GST Included
        </span>

        <div class="form-check form-switch m-0">
          <input
            class="form-check-input"
            type="checkbox"
            id="flexSwitchCheckDefault"
            style="cursor:pointer;"
          />
        </div>
      </div>

    </div>

    <!-- LISTINGS -->
    <div class="row g-3">
      <% for(let listing of allListing){ %>

      <div class="col-12 col-sm-6 col-md-4 col-lg-3">
        <a href="/listings/<%=listing._id%>" class="text-decoration-none text-dark">

          <div class="card h-100 shadow-sm border-0">

            <img
              src="<%=listing.image.url%>"
              class="card-img-top"
              alt="listing image"
              style="height: 200px; object-fit: cover;"
            />

            <div class="card-body p-2">
              <p class="mb-1">
                <b><%=listing.title%></b>
              </p>

              <p class="mb-0 small">
                ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %> / night
                <span class="tax-info text-muted" style="display:none;"> +18% GST</span>
              </p>
            </div>

          </div>

        </a>
      </div>

      <% } %>
    </div>

  </div>

  <!-- SCRIPT -->
  <script>
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");

    taxSwitch.addEventListener("change", () => {
      let taxInfo = document.getElementsByClassName("tax-info");

      for (let info of taxInfo) {
        if (taxSwitch.checked) {
          info.style.display = "inline";
        } else {
          info.style.display = "none";
        }
      }
    });
  </script>

</body>