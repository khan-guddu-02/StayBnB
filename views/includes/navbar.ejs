<style>
  .search-box {
    flex: 1;
    max-width: 400px;
  }

  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1rem;
  }

  .search-btn {
    background-color: #fe424d;
    color: white;
    border-radius: 20px;
    padding: 0.4rem 1rem;
  }

  .search-btn:hover {
    background-color: #fe424d;
    color: white;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">

    <!-- LOGO -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <!-- SEARCH (ALWAYS VISIBLE) -->
    <form class="d-flex search-box mx-2" role="search">
      <input
        class="form-control me-2 search-inp"
        type="search"
        placeholder="Search destination"
      />
      <button class="btn search-btn" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
    </form>

    <!-- TOGGLER -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="offcanvas"
      data-bs-target="#mobileMenu"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- DESKTOP MENU -->
    <div class="d-none d-md-flex ms-auto align-items-center gap-2">

      <!-- Airbnb -->
      <a 
        href="/listings/new"
        class="btn"
        style="border-radius:25px; padding:6px 14px; border:1px solid #ddd;"
      >
        Airbnb your home
      </a>

      <% if(!currentUser){ %>

        <a 
          href="/signup"
          class="btn btn-dark"
          style="border-radius:25px; padding:6px 14px;"
        >
          Signup
        </a>

        <a 
          href="/login"
          class="btn btn-outline-dark"
          style="border-radius:25px; padding:6px 14px;"
        >
          Login
        </a>

      <% } %>

      <% if(currentUser){ %>

        <!-- Dashboard -->
        <a 
          href="/owner/bookings"
          class="btn btn-dark"
          style="border-radius:25px; padding:6px 14px;"
        >
          Dashboard
        </a>

        <!-- My Bookings -->
        <a 
          href="/bookings"
          class="btn btn-outline-dark"
          style="border-radius:25px; padding:6px 14px;"
        >
          My Bookings
        </a>

        <!-- Logout -->
        <a 
          href="/logout"
          class="btn btn-outline-dark"
          style="border-radius:25px; padding:6px 14px;"
        >
          Logout
        </a>

      <% } %>

    </div>

  </div>
</nav>

<!-- MOBILE MENU (OFFCANVAS) -->
<div
  class="offcanvas offcanvas-end"
  tabindex="-1"
  id="mobileMenu"
>
  <div class="offcanvas-header">
    <h5 class="offcanvas-title">Menu</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">

    <a class="nav-link mb-2" href="/listings/new">
      Airbnb your home
    </a>

    <% if(!currentUser){ %>
      <a class="nav-link mb-2" href="/signup">Signup</a>
      <a class="nav-link mb-2" href="/login">Login</a>
    <% } %>

    <% if(currentUser){ %>

      <a class="nav-link mb-2" href="/owner/bookings">
        📊 Dashboard
      </a>

      <a class="nav-link mb-2" href="/bookings">
        📅 My Bookings
      </a>

      <a class="nav-link mb-2" href="/logout">
        🚪 Logout
      </a>

    <% } %>

  </div>
</div>